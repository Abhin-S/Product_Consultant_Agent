# App
SECRET_KEY=replace_with_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
AUTH_MODE=google_sso

# Database
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# PostgreSQL example for deployment:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/product_consultant

# ChromaDB
CHROMA_DB_PATH=./chroma_db
DOCS_DIR=D:\Abhin s\UG4\Sem 2\Applied Gen AI\Final_Project\Case_Study_Data
PARENT_STORE_PATH=./processed_data/parent_chunks.json

# Google AI Studio — Gemma 4
GOOGLE_API_KEY=replace_with_google_api_key
GEMMA_MODEL_NAME=gemma-4-it
LLM_FALLBACK_MODEL_NAME=gemma-3-12b-it

# Google SSO (OAuth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile
AUTH_COOKIE_NAME=pcai_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# RAG
CONFIDENCE_THRESHOLD=0.45
TOP_K_DEFAULT=5
MAX_CONTEXT_TOKENS=3000
LLM_MAX_RETRIES=3
# Set to 0 to disable explicit client-side timeout.
MODEL_REQUEST_TIMEOUT_SECONDS=30
BYPASS_LLM_CALLS=false
ENABLE_QUERY_EXPANSION=true
ENABLE_RELEVANCE_GRADING=true
MULTI_QUERY_COUNT=3
RRF_K=60
CRAG_MIN_RELEVANT_DOCS=2
ENABLE_GROUNDING_CHECK=true
PARENT_CHUNK_SIZE=1800
PARENT_CHUNK_OVERLAP=180
CHILD_CHUNK_SIZE=500
CHILD_CHUNK_OVERLAP=50
MAX_PARENT_CONTEXT_CHUNKS=3

# News
NEWS_API_KEY=
GNEWS_API_KEY=
NEWS_RELEVANCE_THRESHOLD=0.35
NEWS_MAX_AGE_DAYS=30

# Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_with_base64_fernet_key

# OAuth stubs (future)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=

# Evaluation
EVAL_SAMPLE_RATE=10
# Set to 0 to disable timeout
RAGAS_TIMEOUT_SECONDS=0

# Frontend
FRONTEND_URL=http://localhost:3000